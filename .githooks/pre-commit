#!/bin/sh
# Při commitu s jinými soubory než verzí automaticky zvýší číslo verze.
set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

STAGED="$(git diff --cached --name-only)"
[ -z "$STAGED" ] && exit 0

NON_VERSION="$(printf '%s\n' "$STAGED" | grep -cvE '^(version\.json|index\.html)$' || true)"
if [ "$NON_VERSION" -eq 0 ]; then
  exit 0
fi

node scripts/bump-version.js
git add version.json index.html
